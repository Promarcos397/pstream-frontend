{
  "name": "pstream",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.pstream.app",
    "productName": "Pstream",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/**/*",
      "services/**/*",
      ".env",
      "credentials.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pstream",
      "deleteAppDataOnUninstall": true,
      "installerSidebar": "build/installerSidebar.png",
      "uninstallerSidebar": "build/installerSidebar.png",
      "installerHeader": "build/installerHeader.png",
      "installerHeaderIcon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@consumet/extensions": "^1.8.8",
    "@phosphor-icons/react": "^2.1.10",
    "@plasmohq/messaging": "^0.7.2",
    "@scure/bip39": "^2.0.1",
    "@supabase/supabase-js": "^2.93.3",
    "@types/crypto-js": "^4.2.2",
    "@types/dompurify": "^3.2.0",
    "abort-controller": "^3.0.0",
    "axios": "^1.14.0",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "cheerio": "^1.1.2",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dashjs": "^5.1.1",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.38.0",
    "fscreen": "^1.2.0",
    "fuse.js": "^7.1.0",
    "hls-parser": "^0.16.0",
    "hls.js": "^1.6.16",
    "i18next": "^25.7.3",
    "immer": "^11.1.3",
    "iso-639-1": "^3.1.5",
    "js-cookie": "^3.0.5",
    "json5": "^2.2.3",
    "jwt-decode": "^4.0.0",
    "lodash.merge": "^4.6.2",
    "nanoid": "^5.1.6",
    "node-fetch": "^3.3.2",
    "ofetch": "^1.5.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.1",
    "react-router-dom": "^6.30.2",
    "react-youtube": "^10.1.0",
    "slugify": "^1.6.6",
    "subsrt-ts": "^2.1.2",
    "tweetnacl": "^1.0.3",
    "unpacker": "^1.0.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
